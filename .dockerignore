*.log
logs/

# Variables de entorno locales (nunca commitear secretos)
.env
.env.local
.env.*.local

# Documentacion que no va al contenedor
*.md
!README.md

# Docker
Dockerfile
.dockerignore
docker-compose*.yml
.docker/

# Temporal
tmp/
temp/