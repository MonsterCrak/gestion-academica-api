# Control de versiones
.git
.gitignore
.gitattributes

# IDEs
.idea
*.iml
*.iws
*.ipr
.vscode

# Build outputs (se regeneran dentro del contenedor)
target/
build/
out/
*.class
*.jar
!target/dependency-jars/

